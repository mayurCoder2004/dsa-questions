class Solution {
    public int inorderSuccessor(Node root, Node x) {
        // add code here.
        int successor = -1;
        while (root != null) {
            if (root.data > x.data) {
                successor = root.data;
                root = root.left;
            }
            else {
                root = root.right;
            }
        }
        return successor;
    }
}
