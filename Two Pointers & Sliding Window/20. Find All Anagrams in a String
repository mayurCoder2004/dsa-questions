class Solution {
    public List<Integer> findAnagrams(String s, String p) {
        int sl = s.length();
        int pl = p.length();
        int [] sarr = new int[26];
        int [] parr = new int[26];
        List<Integer> ans = new ArrayList<>();

        for (int i=0; i<pl; i++) {
            parr[p.charAt(i) - 'a']++;
        }

        for (int i=0; i<sl; i++) {
            sarr[s.charAt(i) - 'a']++;
            if (i >= pl) {
                sarr[s.charAt(i - pl) - 'a']--;
            }

            if (Arrays.equals(sarr, parr)) {
                ans.add(i - pl + 1);
            }
        }
        return ans;
    }
}
