class Solution {
    public int countSubArray(int [] nums, int k) {
        if (k < 0) return 0;
        int n = nums.length;
        int left = 0, count = 0, ans = 0;

        for (int right=0; right<n; right++) {
            if (nums[right] % 2 == 1) count++;
            while (count > k) {
                if (nums[left] % 2 == 1) count--;
                left++;
            }
            ans += (right - left + 1);
        }
        return ans;
    }
    public int numberOfSubarrays(int[] nums, int k) {
        int nth = countSubArray(nums, k);
        int nth1 = countSubArray(nums, k-1);

        return nth - nth1;
    }
}
