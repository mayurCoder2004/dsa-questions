                                                                  // BRUTE FORCE APPROACH

class Solution {
    public int maximumUniqueSubarray(int[] nums) {
        int n = nums.length;
        int ans = 0;

        for (int i = 0; i < n; i++) {
            HashMap<Integer, Integer> map = new HashMap<>(); // reset for each i
            int sum = 0;

            for (int j = i; j < n; j++) {

                map.put(nums[j], map.getOrDefault(nums[j], 0) + 1);

                // if duplicate found → break
                if (map.get(nums[j]) > 1) {
                    break;
                }

                sum += nums[j];
                ans = Math.max(ans, sum);
            }
        }

        return ans;
    }
}
                                                                  

                                                                      // OPTIMAL APPROACH

class Solution {
    public int maximumUniqueSubarray(int[] nums) {
        int n = nums.length;
        int ans = 0;
        int left = 0;
        int right = 0;
        int sum = 0;
        HashSet<Integer> set = new HashSet<>();

        while(right < n) {
            // Remove if element is already present
            while (set.contains(nums[right])) {
                set.remove(nums[left]);
                sum -= nums[left];
                left++;
            }

            set.add(nums[right]);
            sum += nums[right];

            ans = Math.max(sum, ans);
            right++;
        }

        return ans;
    }
}
