class Solution {
    public int maxFrequency(int[] nums, int k) {
        int n = nums.length;
        int left = 0, right = 0, ans = 0;
        Arrays.sort(nums);
        long sum = 0;

        while (right < n) {
            sum += nums[right];   

            while ((long) nums[right] * (right - left + 1) - sum > k) {
                sum -= nums[left];
                left++;
            }

            ans = Math.max(ans, right - left + 1);
            right++;
        }
        return ans;
    }
}
