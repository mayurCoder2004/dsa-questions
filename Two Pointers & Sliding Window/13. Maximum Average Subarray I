                                                                // BRUTE FORCE APPROACH

class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        if (n == 1) {
            return (double) nums[0];
        }
        double max = 0;
        for (int i=0; i<n-k+1; i++) {
            double sum = 0;
            for (int j=i; j<i+k; j++) {
                sum += nums[j];
            }
            double avg = sum / k;
            max = Math.max(avg, max);
        }
        return max;
    }
}                                                                


                                                                  // OPTIMAL APPROACH

class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;

        // Finding the sum of first window
        int sum = 0;
        for (int i=0; i<k; i++) {
            sum += nums[i];
        }

        int max = sum;

        // Start sliding window
        int left = 0, right = k;
        while (right < n) {
            // Removing the first element 
            sum = sum - nums[left];
            left++;

            // Adding the last element
            sum = sum + nums[right];
            right++;

            max = Math.max(max, sum);
        }
        return (double) max / k;
    }
}
