class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        if (n == 1) {
            return (double) nums[0];
        }
        double max = 0;
        for (int i=0; i<n-k+1; i++) {
            double sum = 0;
            for (int j=i; j<i+k; j++) {
                sum += nums[j];
            }
            double avg = sum / k;
            max = Math.max(avg, max);
        }
        return max;
    }
}                                                                
