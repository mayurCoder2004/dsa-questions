class Solution {
    public int maxVowels(String s, int k) {
        int n = s.length();

        int vowels = 0;
        int count = 0;
        // Getting the initial window
        for (int i=0; i<k; i++) {
            char ch = s.charAt(i);
            if (ch == 'a' || ch == 'i' || ch == 'e' || ch == 'u' || ch == 'o') {
                count++;
            }
        }
        vowels = count;

        int left = 0, right = k;

        while (right < n) {
            char cl = s.charAt(left);
            if (cl == 'a' || cl == 'i' || cl == 'e' || cl == 'u' || cl == 'o') {
                count--;
            }

            char cr = s.charAt(right);
            if (cr == 'a' || cr == 'i' || cr == 'e' || cr == 'u' || cr == 'o') {
                count++;
            }

            vowels = Math.max(vowels, count);
            left++;
            right++;
        }
        return vowels;
    }
}
