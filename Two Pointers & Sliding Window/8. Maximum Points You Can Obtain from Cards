                                                              // BRUTE FORCE APPROACH

class Solution {
    public int maxScore(int[] cardPoints, int k) {
        int n = cardPoints.length;
        int rem = n - k;
        int min = Integer.MAX_VALUE;
        int totalSum = 0;

        for (int i=0; i<n; i++) {
            totalSum += cardPoints[i];
        }

        for (int i=0; i<=n-rem; i++) {
            int sum = 0;
            for (int j=i; j<i+rem; j++) {
                sum += cardPoints[j];
            }
            min = Math.min(sum, min);
        }
        return totalSum - min;
    }
}


                                                              // OPTIMAL APPROACH

class Solution {
    public int maxScore(int[] cardPoints, int k) {
        int n = cardPoints.length;
        int rem = n-k;
        int sum = 0;

        for (int i=0; i<n; i++) {
            sum += cardPoints[i];
        }

        if (rem == 0) return sum;

        int currSum = 0;
        for (int i = 0; i < rem; i++) currSum += cardPoints[i];
        int minSum = currSum;

        for (int i = rem; i < n; i++) {
            currSum += cardPoints[i] - cardPoints[i - rem];
            minSum = Math.min(minSum, currSum);
        }

        return sum - minSum;
    }
}
