class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        // Code here
        int n = arr.length;
        
        int sum = 0;
        
        for (int i=0; i<k; i++) {
            sum += arr[i];
        }
        
        int left = 0, right = k;
        int ans = sum;
        
        while (right < n) {
            sum = sum - arr[left];
            left++;
            
            sum = sum + arr[right];
            right++;
            
            ans = Math.max(ans, sum);
        }
        return ans;
    }
}
