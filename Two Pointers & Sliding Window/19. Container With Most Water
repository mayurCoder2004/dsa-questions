                                                                      // BRUTE FORCE APPROACH

class Solution {
    public int maxArea(int[] height) {
        int n = height.length;

        int max = 0;

        for (int i=0; i<n; i++) {
            for (int j=i; j<n; j++) {
                int h = Math.min(height[i], height[j]);
                int width = j - i;
                int area = h * width;
                max = Math.max(max, area);
            }
        }
        return max;
    }
}                                                                      


                                                                      // OPTIMAL APPROACH

class Solution {
    public int maxArea(int[] height) {
        int n = height.length;
        int maxArea = 0;
        int st = 0, end = n-1;

        while (st <= end) {
            int area = Math.min(height[st], height[end]) * (end - st);
            maxArea = Math.max(area, maxArea);

            if (height[st] < height[end]) {
                st++;
            }
            else {
                end--;
            }
        }
        return maxArea;
    }
}
