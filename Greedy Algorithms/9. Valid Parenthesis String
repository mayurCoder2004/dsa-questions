                                                  // BRUTE FORCE APPROACH

class Solution {
    public boolean helper(String s, int idx, int count) {
        if (count < 0) {
            return false;
        }
        if (idx == s.length()) {
            return (count == 0);
        }

        if (s.charAt(idx) == '(') {
            return helper(s, idx+1, count+1);
        }
        if (s.charAt(idx) == ')') {
            return helper(s, idx+1, count-1);
        }
        return helper(s, idx+1, count+1) || helper(s, idx+1, count-1) || helper(s, idx+1, count);
    }
    public boolean checkValidString(String s) {
        return helper(s, 0, 0);
    }
}


                                                    // OPTIMAL APPROACH

                                                    
class Solution {
    public boolean checkValidString(String s) {
        int n = s.length();
        int min = 0, max = 0;

        for (int i=0; i<n; i++) {
            char ch = s.charAt(i);
            if (ch == '(') {
                min = min + 1;
                max = max + 1;
            }
            else if (ch == ')') {
                min = min - 1;
                max = max - 1;
            }
            else {
                min = min - 1;
                max = max + 1;
            }

            if (min < 0) {
                min = 0;
            }
            if (max < 0) {
                return false;
            }
        }
        return (min == 0);
    }
}
