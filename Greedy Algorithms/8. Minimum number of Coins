class Solution {
    public int findMin(int cash) {
        // code here
        int [] arr = new int[4];
        arr[0] = 10;
        arr[1] = 5;
        arr[2] = 2;
        arr[3] = 1;
        int count = 0;
        
        for (int i=0; i<4; i++) {
            count += (cash / arr[i]);
            cash -= (cash / arr[i]) * arr[i];
        }
        return count;
    }
}
