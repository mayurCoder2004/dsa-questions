class Solution {
    public int maxOperations(String s) {
        int n = s.length();
        int count_ones = 0;
        int res = 0;

        for (int i=0; i<n; i++) {
            char ch = s.charAt(i);
            if (ch == '1') {
                count_ones++;
            }
            else {
                if (i == n - 1 || s.charAt(i + 1) == '1') {
                    res += count_ones;
                }
            }
        }
        return res;
    }
}
