                                                          // APPROACH 1

class Solution {
    public int pivotIndex(int[] nums) {
        int n = nums.length;
        int [] suffix = new int[n];
        suffix[n-1] = nums[n-1];

        for (int i=n-2; i>=0; i--) {
            suffix[i] = nums[i] + suffix[i+1];
        }

        int prefSum = 0;
        for (int i=0; i<n; i++) {
            if (prefSum == suffix[i] - nums[i]) {
                return i;
            }
            prefSum += nums[i];
        }
        return -1;
    }
}


                                                          // APPROACH 2

class Solution {
    public int pivotIndex(int[] nums) {
        int n = nums.length;
        int totalSum = 0;

        for (int i=0; i<n; i++) {
            totalSum += nums[i];
        }

        int leftSum = 0;
        for (int i=0; i<n; i++) {
            if (leftSum == totalSum - leftSum - nums[i]) {
                return i;
            }
            leftSum += nums[i];
        }
        return -1;
    }
}                                                          
