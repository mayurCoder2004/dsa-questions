                                                                // BRUTE FORCE APPROACH

// User function Template for Java
class Solution {
    static int setBits(int n) {
        // code here
        int count = 0;
        
        while (n > 1) {
            if (n % 2 == 1) {
                count++;
            }
            n = n / 2;
        }
        
        if (n == 1) {
            count++;
        }
        return count;
    }
}



