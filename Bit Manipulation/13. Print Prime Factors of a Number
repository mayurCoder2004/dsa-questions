import java.util.ArrayList;

class Solution {
    public static ArrayList<Integer> primeFac(int n) {
        ArrayList<Integer> ans = new ArrayList<>();
        if (n <= 1) return ans; // no prime factors for 0 or 1

        // 1. Handle factor 2 once, then remove all powers of 2
        if ((n & 1) == 0) {
            ans.add(2);
            while ((n & 1) == 0) {
                n >>= 1;
            }
        }

        // 2. Handle odd factors; add each factor once and remove its powers
        for (int i = 3; (long) i * i <= n; i += 2) {
            if (n % i == 0) {
                ans.add(i);
                while (n % i == 0) {
                    n /= i;
                }
            }
        }

        // 3. If remaining n is a prime > 2, add it once
        if (n > 2) ans.add(n);

        return ans;
    }
}
