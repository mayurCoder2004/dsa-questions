                                                            // BRUTE FORCE APPROACH

class Solution {
    public int [] computePrime(int n) {
        int [] prime = new int[n+1];

        for (int i=2; i<n; i++) {
            prime[i] = 1;
        }

        for (int i=2; i<n; i++) {
            if (prime[i] == 1) {
                for (int j=2*i; j<n; j+=i) {
                    prime[j] = 0;
                }
            }
        }
        return prime;
    }
    public int countPrimes(int n) {
        if (n == 0 || n == 1 || n == 2) {
            return 0;
        }

        int [] prime = computePrime(n);
        int count = 0;

        for (int i=2; i<n; i++) {
            if (prime[i] == 1) {
                count++;
            }
        }
        return count;
    }
}                                                            
