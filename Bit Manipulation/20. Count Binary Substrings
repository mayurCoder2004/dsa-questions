class Solution {
    public int countBinarySubstrings(String s) {
        int prevGroup = 0;
        int currGroup = 1;
        int answer = 0;

        for (int i=1; i<s.length(); i++) {
            if (s.charAt(i) == s.charAt(i-1)) {
                currGroup++;
            }
            else {
                prevGroup = currGroup;
                currGroup = 1;
            }

            if (prevGroup >= currGroup) {
                answer++;
            }
        }
        return answer;
    }
}
