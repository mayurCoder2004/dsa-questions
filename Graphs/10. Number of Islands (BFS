class pair{
    int first;
    int second;
    public pair(int first, int second) {
        this.first = first;
        this.second = second;
    }
}
class Solution {
    public boolean isSafe(int i, int j, int m, int n) {
        return (i >= 0 && i < m && j >= 0 && j < n);
    }
    public int numIslands(char[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        boolean [][] vis = new boolean[m][n];
        int count = 0;

        for (int i=0; i<m; i++) {
            for (int j=0; j<n; j++) {
                if (grid[i][j] == '1' && !vis[i][j]) {
                    count++;
                    Queue<pair> q = new LinkedList<>();
                    q.add(new pair(i, j));
                    vis[i][j] = true;

                    while (!q.isEmpty()) {
                        pair curr = q.remove();
                        int curri = curr.first;
                        int currj = curr.second;

                        int [][] dir = {{0, 1}, {0, -1}, {1, 0}, {-1, 0}};
                        for (int k=0; k<4; k++) {
                            int newi = curri + dir[k][0];
                            int newj = currj + dir[k][1];
                            if (isSafe(newi, newj, m, n) && grid[newi][newj] == '1' && !vis[newi][newj]) {
                                vis[newi][newj] = true;
                                q.add(new pair(newi, newj));
                            }
                        }
                    }
                }
            }
        }
        return count;
    }
}
