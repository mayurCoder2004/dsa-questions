class Solution {
    public void dfs(int[][] isConnected, boolean [] visited, int curr, int n) {
        for (int i=0; i<n; i++) {
            if (isConnected[curr][i] == 1 && !visited[i]) {
                visited[i] = true;
                dfs(isConnected, visited, i, n);
            }
        }
    }
    public int findCircleNum(int[][] isConnected) {
        int n = isConnected.length;
        boolean [] visited = new boolean[n];
        int count = 0;

        for (int i=0; i<n; i++) {
            if (!visited[i]) {
                count++;
                dfs(isConnected, visited, i, n);
            }
        }
        return count;
    }
}
