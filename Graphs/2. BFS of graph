class Solution {
    public ArrayList<Integer> bfs(ArrayList<ArrayList<Integer>> adj) {
        // code here
        ArrayList<Integer> bfs = new ArrayList<>();
        boolean [] visited = new boolean[adj.size()];
        Queue<Integer> q = new LinkedList<>();
        
        q.add(0);
        visited[0] = true;
        
        while (!q.isEmpty()) {
            int node = q.poll();
            bfs.add(node);
            
            for (int it: adj.get(node)) {
                if (visited[it] == false) {
                    visited[it] = true;
                    q.add(it);
                }
            }
        }
        
        return bfs;
    }
}
