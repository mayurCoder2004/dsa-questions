class Solution {

    public void dfs(int[][] grid, int i, int j, boolean[] isClosed) {

        int m = grid.length;
        int n = grid[0].length;

        // If island touches boundary
        if (i < 0 || j < 0 || i >= m || j >= n) {
            isClosed[0] = false;
            return;
        }

        // Water or already visited
        if (grid[i][j] == 1) {
            return;
        }

        // Mark visited
        grid[i][j] = 1;

        // Explore 4 directions
        dfs(grid, i + 1, j, isClosed);
        dfs(grid, i - 1, j, isClosed);
        dfs(grid, i, j + 1, isClosed);
        dfs(grid, i, j - 1, isClosed);
    }

    public int closedIsland(int[][] grid) {

        int m = grid.length;
        int n = grid[0].length;

        int count = 0;

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {

                if (grid[i][j] == 0) {

                    boolean[] isClosed = {true};

                    dfs(grid, i, j, isClosed);

                    if (isClosed[0]) {
                        count++;
                    }
                }
            }
        }

        return count;
    }
}
