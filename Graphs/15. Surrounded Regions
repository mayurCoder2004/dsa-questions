class Solution {
    public boolean isSafe(int i, int j, int m, int n) {
        return (i >= 0 && i < m && j >= 0 && j < n); 
    }
    public void floodFill(int i, int j, int r, int c, char[][] board) {
        board[i][j] = 'V';

        int [][] dirs = {{-1, 0}, {1, 0}, {0, -1}, {0, 1}};

        for (int k=0; k<4; k++) {
            int newr = i + dirs[k][0];
            int newc = j + dirs[k][1];
            if (isSafe(newr, newc, r, c) && board[newr][newc] == 'O') {
                floodFill(newr, newc, r, c, board);
            }
        }
    }
    public void solve(char[][] board) {
        int m = board.length;
        int n = board[0].length;

        // step 1: convert boundary values O to V
        for (int j=0; j<n; j++) {
            if (board[0][j] == 'O') floodFill(0, j, m, n, board);
            if (board[m-1][j] == 'O') floodFill(m-1, j, m, n, board);
        }

        for (int i=0; i<m; i++) {
            if (board[i][0] == 'O') floodFill(i, 0, m, n, board);
            if (board[i][n-1] == 'O') floodFill(i, n-1, m, n, board);
        }

        // step 2: convert remaining Os to X
        for (int i=0; i<m; i++) {
            for (int j=0; j<n; j++) {
                if (board[i][j] == 'O') {
                    board[i][j] = 'X';
                }
            }
        }

        // step 3: convert Vs to O
        for (int i=0; i<m; i++) {
            for (int j=0; j<n; j++) {
                if (board[i][j] == 'V') {
                    board[i][j] = 'O';
                }
            }
        }
    }
}
