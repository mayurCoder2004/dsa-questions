class Solution {
    public boolean dfs(boolean [][] graph, int source, int destination, int n, boolean [] visited) {
        if (source == destination) {
            return true;
        }
        visited[source] = true;
        for (int i=0; i<n; i++) {
            if (graph[source][i] == true && !visited[i]) {
                if (dfs(graph, i, destination, n, visited)) {
                    return true;
                }
            }
        }

        return false;
    }
    public boolean validPath(int n, int[][] edges, int source, int destination) {
        boolean [][] graph = new boolean[n][n];
        
        for (int [] edge: edges) {
            int u = edge[0], v = edge[1];
            graph[u][v] = true;
            graph[v][u] = true;
        }

        boolean [] visited = new boolean[n];
        return dfs(graph, source, destination, n, visited);
    }
}
