class Solution {
    public int digitFrequencyScore(int n) {
        int [] freq = new int[10];
        int temp = n;

        while (temp > 0) {
            int digit = temp % 10;
            freq[digit]++;
            temp = temp / 10;
        }

        int ans = 0;
        for (int i=0; i<10; i++) {
            ans += (i * freq[i]);
        }
        return ans;
    }
}
