class Solution {
    public int count(int num) {
        int count = 0;
        while (num > 0) {
            count++;
            num = num / 10;
        }
        return count;
    }
    public int findNumbers(int[] nums) {
        int n = nums.length;
        int ans = 0;

        for (int i=0; i<n; i++) {
            int count = count(nums[i]);
            if (count % 2 == 0) {
                ans++;
            }
        }
        return ans;
    }
}
