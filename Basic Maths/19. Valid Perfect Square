class Solution {
    public boolean isPerfectSquare(int num) {
        int st = 1, end = num;

        while (st <= end) {
            int mid = st + (end - st) / 2;
            long sqr = (long) mid * mid;
            if (sqr == num) {
                return true;
            }
            else if (sqr > num) {
                end = mid - 1;
            }
            else {
                st = mid + 1;
            }
        }
        return false;
    }
}
