class Solution {
    public int digitSum(int n) {
        int sum = 0;
        while (n != 0) {
            int digit = n % 10;
            sum += digit;
            n = n / 10;
        }
        return sum;
    }
    public int minElement(int[] nums) {
        int n = nums.length;
        int min = Integer.MAX_VALUE;

        for (int i=0; i<n; i++) {
            int sum = digitSum(nums[i]);
            min = Math.min(sum, min);
        }
        return min;
    }
}
