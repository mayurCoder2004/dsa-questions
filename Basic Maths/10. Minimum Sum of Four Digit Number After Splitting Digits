class Solution {
    public int minimumSum(int num) {
        int [] ans = new int[4];
        int k = 0;

        while (num > 0) {
            ans[k++] = num % 10;
            num = num / 10;
        }

        Arrays.sort(ans);

        int n1 = ans[0] * 10 + ans[2];
        int n2 = ans[1] * 10 + ans[3];

        return n1 + n2;
    }
}
