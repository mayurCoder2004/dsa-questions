class Solution {
    public boolean judgeSquareSum(int c) {
        long low = 0, high = (long) Math.sqrt(c);

        while (low <= high) {
            long ans = low * low + high * high;
            if (ans == c) {
                return true;
            }
            else if (ans > c) {
                high--;
            }
            else {
                low++;
            }
        }
        return false;
    }
}
