class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];
        
        // Step 1: Initialize with 1
        for (int i = 0; i < n; i++) {
            ans[i] = 1;
        }

        int prodL = 1; // prefix product
        int prodR = 1; // suffix product

        // Step 2: Prefix pass (left to right)
        for (int i = 0; i < n; i++) {
            ans[i] *= prodL;
            prodL *= nums[i];
        }

        // Step 3: Suffix pass (right to left)
        for (int i = n - 1; i >= 0; i--) {
            ans[i] *= prodR;
            prodR *= nums[i];
        }

        return ans;
    }
}
