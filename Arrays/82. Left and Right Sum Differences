class Solution {
    public int [] leftSum(int [] nums) {
        int n = nums.length;
        int [] ans = new int[n];
        ans[0] = 0;
        for (int i=1; i<n; i++) {
            ans[i] = ans[i] + nums[i-1] + ans[i-1];
        }
        return ans;
    }
    public int [] rightSum(int [] nums) {
        int n = nums.length;
        int [] ans = new int[n];
        ans[n-1] = 0;
        for (int i=n-2; i>=0; i--) {
            ans[i] = ans[i] + nums[i+1] + ans[i+1];
        }
        return ans;
    }
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int [] left = leftSum(nums);
        int [] right = rightSum(nums);

        int [] ans = new int[n];

        for (int i=0; i<n; i++) {
            ans[i] = Math.abs(left[i] - right[i]);
        }
        return ans;
    }
}
