class Solution {
    public int minMoves2(int[] nums) {
        int n = nums.length;
        int min = Integer.MAX_VALUE;
        Arrays.sort(nums);
        int median = nums[n/2];
        int sum = 0;

        for (int i=0; i<n; i++) {
            sum += Math.abs(nums[i] - median);
        }
        return sum;
    }
}
