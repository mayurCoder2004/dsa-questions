class Solution {
    public boolean isValidSudoku(char[][] board) {
        int m = board.length;
        int n = board.length;
        HashSet<String> set = new HashSet<>();

        for (int i=0; i<m; i++) {
            for (int j=0; j<n; j++) {
                if (board[i][j] != '.') {
                    char num = board[i][j];
                    String row = num + " row " + i;
                    String col = num + " col " + j;
                    int boxNum = (i / 3) * 3 + (j / 3);
                    String box = num + " box " + boxNum;
                    if (set.contains(row) || set.contains(col) || set.contains(box)) {
                        return false;
                    }
                    else {
                        set.add(row);
                        set.add(col);
                        set.add(box);
                    }
                }
            }
        }
        return true;
    }
}
