class Solution {
    public int minOperations(int[] nums) {
        int n = nums.length;
        int max = 0, ops = 0;

        for (int i=0; i<n; i++) {
            if (max >= nums[i]) {
                int incre = max - nums[i] + 1;
                nums[i] = nums[i] + incre;
                ops += incre;
            }
            max = nums[i];
        }
        return ops;
    }
}
