class Solution {
    public char nextGreatestLetter(char[] letters, char target) {
        int n = letters.length;
        boolean flag = false;
        int idx = 0;

        for (int i=0; i<n; i++) {
            if (letters[i] - 'a' > target - 'a') {
                flag = true;
                idx = i;
                break;
            }
        }
        if (flag) {
            return letters[idx];
        }

        return letters[0];
    }
}
