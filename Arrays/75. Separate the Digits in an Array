class Solution {
    public int[] separateDigits(int[] nums) {
        ArrayList<Integer> ans = new ArrayList<>();
        int n = nums.length;

        for (int i=0; i<n; i++) {
            int num = nums[i];
            String s = String.valueOf(num);
            for (int j=0; j<s.length(); j++) {
                char ch = s.charAt(j);
                ans.add(ch - '0');
            }
        }
        
        int[] arr = new int[ans.size()];
        for (int i = 0; i < ans.size(); i++) {
            arr[i] = ans.get(i);
        }

        return arr;
    }
}
