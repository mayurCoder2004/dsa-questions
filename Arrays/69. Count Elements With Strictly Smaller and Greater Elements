class Solution {
    public int countElements(int[] nums) {
        int n = nums.length;
        int ans = 0;

        for (int i=0; i<n; i++) {
            int s = 0;
            int l = 0;
            for (int j=0; j<n; j++) {
                if (nums[i] > nums[j]) {
                    l++;
                }
                if (nums[i] < nums[j]) {
                    s++;
                }
            }
            if (l >= 1 && s >= 1) {
                ans++;
            }
        }
        return ans;
    }
}
