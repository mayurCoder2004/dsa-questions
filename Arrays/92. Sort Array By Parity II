class Solution {
    public int[] sortArrayByParityII(int[] nums) {
        int n = nums.length;

        int [] ans = new int[n];
        int k = 0;

        for (int i=0; i<n; i++) {
            if (nums[i] % 2 == 0) {
                ans[k] = nums[i];
                k += 2;
            }
        }

        k = 1;
        for (int i=0; i<n; i++) {
            if (nums[i] % 2 == 1) {
                ans[k] = nums[i];
                k += 2;
            }
        }
        return ans;
    }
}                                                          
