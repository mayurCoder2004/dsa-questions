                                                                // BRUTE FORCE APPROACH

class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n = nums.length;

        int [] ans = new int[n];
        int k = 0;

        for (int i=0; i<n; i++) {
            int prod = 1;
            for (int j=0; j<n; j++) {
                if (i != j) {
                    prod *= nums[j];
                }
            }
            ans[k++] = prod;
        }
        return ans;
    }
}                                                                
