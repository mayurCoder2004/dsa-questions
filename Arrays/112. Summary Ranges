class Solution {
    public List<String> summaryRanges(int[] nums) {
        int n = nums.length;
        List<String> ans = new ArrayList<>();
        if (n == 0) {
            return ans;
        }
        int st = nums[0], end = nums[0];

        for (int i=1; i<n; i++) {
            if (nums[i] == nums[i-1] + 1) {
                end = nums[i];
            }
            else if (nums[i] != nums[i-1] + 1) {
                if (st == end) {
                    ans.add("" + end);
                }
                else {
                    ans.add(st + "->" + end);
                }
                st = end = nums[i];
            }
        }

        if (st == end) {
            ans.add(String.valueOf(st));
        } else {
            ans.add(st + "->" + end);
        }

        return ans;
    }
}
