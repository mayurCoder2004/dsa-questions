class Solution {
    public List<Boolean> prefixesDivBy5(int[] nums) {
        List<Boolean> ans = new ArrayList<>();
        int n = nums.length;
        int current = 0;

        for (int i=0; i<n; i++) {
            current = (current * 2 + nums[i]) % 5;
            if (current == 0) {
                ans.add(true);
            } 
            else {
                ans.add(false);
            }
        }
        return ans;
    }
}
