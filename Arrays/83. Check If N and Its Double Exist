class Solution {
    public boolean checkIfExist(int[] nums) {
        int n = nums.length;
        HashSet<Integer> set = new HashSet<>();
        int zeroes = 0;

        for (int i=0; i<n; i++) {
            if (nums[i] == 0) {
                zeroes++;
            }
            set.add(nums[i]);
        }

        if (zeroes > 1) {
            return true;
        }

        for (int i=0; i<n; i++) {
            if (nums[i] != 0 && set.contains(nums[i] * 2)) {
                return true;
            }
        }
        return false;
    }
}
