class Solution {
    public void helper(ArrayList<Integer> ans, int idx, int sum, int [] arr, int n) {
        if (idx == n) {
            ans.add(sum);
            return;
        }
        
        // Pick element 
        helper(ans, idx+1, sum+arr[idx], arr, n);
        
        // Not pick element
        helper(ans, idx+1, sum, arr, n);
    }
    public ArrayList<Integer> subsetSums(int[] arr) {
        // code here
        int n = arr.length;
        ArrayList<Integer> ans = new ArrayList<>();
        helper(ans, 0, 0, arr, n);
        return ans;
    }
}
