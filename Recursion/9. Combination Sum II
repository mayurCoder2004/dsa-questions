import java.util.*;

class Solution {
    public void helper(int idx, int[] arr, int target, List<List<Integer>> ans, List<Integer> ds) {
        // Base case: if target reached
        if (target == 0) {
            ans.add(new ArrayList<>(ds));
            return;
        }

        for (int i = idx; i < arr.length; i++) {
            // Skip duplicate elements at the same recursion level
            if (i > idx && arr[i] == arr[i - 1]) continue;

            // If current element is greater than target, no need to continue
            if (arr[i] > target) break;

            // Pick the element
            ds.add(arr[i]);

            // Move to next index (no reuse of same element)
            helper(i + 1, arr, target - arr[i], ans, ds);

            // Backtrack
            ds.remove(ds.size() - 1);
        }
    }

    public List<List<Integer>> combinationSum2(int[] candidates, int target) {
        List<List<Integer>> ans = new ArrayList<>();
        Arrays.sort(candidates); 
        helper(0, candidates, target, ans, new ArrayList<>());
        return ans;
    }
}
