class Solution {
    public void helper(ArrayList<String> ans, int open, int closed, int total, String str) {
        if (str.length() == 2*total) {
            ans.add(str);
            return;
        }

        if (open < total) {
            helper(ans, open+1, closed, total, str+"(");
        }

        if (closed < open) {
            helper(ans, open, closed+1, total, str+")");
        }
    }
    public List<String> generateParenthesis(int n) {
        ArrayList<String> ans = new ArrayList<>();
        helper(ans, 0, 0, n, "");
        return ans;
    }
}
