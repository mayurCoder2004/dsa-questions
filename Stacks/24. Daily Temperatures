class Solution {
    public int [] nge(int [] arr) {
        int n = arr.length;
        int [] nge = new int[n];
        Stack<Integer> st = new Stack<>();

        st.push(n-1);
        nge[n-1] = -1;  
        for (int i=n-2; i>=0; i--) {
            while (!st.isEmpty() && arr[i] >= arr[st.peek()]) {
                st.pop();
            }
            if (st.isEmpty()) {
                nge[i] = -1;
            }
            else {
                nge[i] = st.peek();
            }
            st.push(i);
        }
        return nge;
    }
    public int[] dailyTemperatures(int[] temperatures) {
        int n = temperatures.length;
        int [] nge = nge(temperatures);
        int [] ans = new int[n];

        for (int i=0; i<n; i++) {
            if (nge[i] == -1) {
                ans[i] = 0;
            }
            else {
                ans[i] = nge[i] - i;
            }
        }
        return ans;
    }
}
