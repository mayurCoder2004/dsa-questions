class Solution {
    public int mostWordsFound(String[] sentences) {
        int n = sentences.length;
        int ans = 0;

        for (int i=0; i<n; i++) {
            String s = sentences[i];
            int count = 0;
            for (int j=0; j<s.length(); j++) {
                char ch = s.charAt(j);
                if (ch == ' ') {
                    count++;
                }
            }
            count++;
            ans = Math.max(count, ans);
        }
        return ans;
    }
}
