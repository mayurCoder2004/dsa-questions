class Solution {
    public boolean detectCapitalUse(String word) {
        int n = word.length();
        int count = 0;

        for (int i=0; i<n; i++) {
            int ascii = (int) word.charAt(i);
            if (ascii >= 65 && ascii <= 90) {
                count++;
            }
        }

        return ((count == 1 && word.charAt(0) >= 'A' && word.charAt(0) <= 'Z') || count == n || count == 0);
    }
}
