class Solution {
    public boolean checkString(String s) {
        int n = s.length();
        int i = 0;

        while (i < n) {
            if (s.charAt(i) == 'a') {
                i++;
            }
            else {
                break;
            }
        }

        for (int j=i; j<n; j++) {
            if (s.charAt(j) == 'a') {
                return false;
            }
        }
        return true;
    }
}
