class Solution {
    public boolean areOccurrencesEqual(String s) {
        HashMap<Character, Integer> map = new HashMap<>();
        int n = s.length();

        for (int i=0; i<n; i++) {
            char ch = s.charAt(i);
            map.put(ch, map.getOrDefault(ch, 0) + 1);
        }

        int freq = -1;
        for (int value: map.values()) {
            if (freq == -1) {
                freq = value;
            } else if (freq != value) {
                return false;
            }
        }
        return true;
    }
}
