class Solution {
    public boolean canConstruct(String ransomNote, String magazine) {
        int n1 = ransomNote.length();
        int n2 = magazine.length();
        HashMap<Character, Integer> m1 = new HashMap<>();
        HashMap<Character, Integer> m2 = new HashMap<>();

        for (int i=0; i<n1; i++) {
            m1.put(ransomNote.charAt(i), m1.getOrDefault(ransomNote.charAt(i), 0) + 1);
        }

        for (int i=0; i<n2; i++) {
            m2.put(magazine.charAt(i), m2.getOrDefault(magazine.charAt(i), 0) + 1);
        }

        for (Map.Entry<Character, Integer> entry : m1.entrySet()) {
            char ch = entry.getKey();
            int need = entry.getValue();

            if (!m2.containsKey(ch) || m2.get(ch) < need) {
                return false;
            }
        }
        return true;
    }
}
