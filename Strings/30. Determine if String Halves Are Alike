class Solution {
    public boolean halvesAreAlike(String s) {
        int lc = 0, rc = 0;
        int n = s.length();
        s = s.toLowerCase();

        for (int i=0; i<n/2; i++) {
            char ch = s.charAt(i);
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u') {
                lc++;
            }
        }

        for (int i=n/2; i<n; i++) {
            char ch = s.charAt(i);
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u') {
                rc++;
            }
        }

        return (lc == rc);
    }
}
