                                                                // BRUTE FORCE APPROACH

class Solution {
    public int maxDepth(String s) {
        int n = s.length();

        Stack<Character> st = new Stack<>();

        int depth = 0;
        int maxDepth = 0;

        for (int i=0; i<n; i++) {
            char ch = s.charAt(i);
            if (ch == '(') {
                depth++;
                st.push(ch);
            }
            else if (ch == ')') {
                depth--;
                if (!st.isEmpty()) st.pop();
            }
            maxDepth = Math.max(maxDepth, depth);
        }
        return maxDepth;
    }
}


                                                                // OPTIMAL APPROACH

class Solution {
    public int maxDepth(String s) {
        int n = s.length();
        int maxCount = 0;
        int count = 0;

        for (int i=0; i<n; i++) {
            char ch = s.charAt(i);
            if (ch == '(') {
                count++;
            }
            else if (ch == ')') {
                count--;
            }
            maxCount = Math.max(maxCount, count);
        }
        return maxCount;
    }
}
