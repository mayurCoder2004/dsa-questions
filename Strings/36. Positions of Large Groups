class Solution {
    public List<List<Integer>> largeGroupPositions(String s) {
        int n = s.length();
        List<List<Integer>> ans = new ArrayList<>();

        int i = 0;

        while (i < n) {
            int j = i;

            while (j < n && s.charAt(j) == s.charAt(i)) {
                j++;
            }

            if (j - i >= 3) {
                List<Integer> group = new ArrayList<>();
                group.add(i);
                group.add(j - 1);
                ans.add(group);
            }

            i = j;
        }

        return ans;
    }
}
