class Solution {
    public int maxPower(String s) {
        int n = s.length();
        int count = 1, maxCount = 1;

        for (int i=0; i<n-1; i++) {
            if (s.charAt(i) == s.charAt(i+1)) {
                count++;
            }
            else {
                maxCount = Math.max(maxCount, count);
                count = 1;
            }
        }

        maxCount = Math.max(maxCount, count);
        
        return maxCount;
    }
}
