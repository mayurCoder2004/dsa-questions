class Solution {
    public boolean areAlmostEqual(String s1, String s2) {
        int n1 = s1.length();
        int n2 = s2.length();
        int first = -1, second = -1;
        int count = 0;

        for (int i=0; i<n1; i++) {
            if (s1.charAt(i) != s2.charAt(i)) {
                count++;
                if (count > 2) {
                    return false;
                }
                if (first == -1) {
                    first = i;
                }
                else if (second == -1) {
                    second = i;
                }
            }
        }

        if (count == 0) {
            return true;
        }
        
        if (count == 2) {
            return s1.charAt(first) == s2.charAt(second) && s2.charAt(first) == s1.charAt(second);
        }

        return false;
    }
}
