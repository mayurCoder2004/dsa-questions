class Solution {
    public String replaceDigits(String s) {
        int n = s.length();
        String ans = "";

        for (int i=0; i<n; i+=2) {
            char ch = s.charAt(i);
            if (!(ch >= '0' && ch <= '9')) {
                ans += ch;
                if (i != n-1) {
                    int val = s.charAt(i+1) - '0';
                    int a = (int) ch + val;
                    char c = (char) a;
                    ans += c;
                }
            }
        }
        return ans;
        
    }
}
