class Solution {
    public int maximumValue(String[] strs) {
        int n = strs.length;
        int max = 0;

        for (int i=0; i<n; i++) {
            String s = strs[i];
            int count = 0;
            for (int j=0; j<s.length(); j++) {
                char ch = s.charAt(j);
                if (ch >= '0' && ch <= '9') {
                    count++;
                }
            }
            if (count == s.length()) {
                int num = Integer.parseInt(s);
                max = Math.max(num, max);
            }
            else {
                max = Math.max(s.length(), max);
            }
        }
        return max;
    }
}
