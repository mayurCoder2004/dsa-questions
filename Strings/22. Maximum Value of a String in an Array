class Solution {
    public int maximumValue(String[] strs) {
        int n = strs.length;
        int max = 0;

        for (int i=0; i<n; i++) {
            String s = strs[i];
            int val = 0;
            if (s.matches("\\d+")) {
                val = Integer.parseInt(s);
            }
            else {
                val = s.length();
            }
            max = Math.max(max, val);
        }
        return max;
    }
}
