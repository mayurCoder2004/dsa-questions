class Solution {
    public int lengthOfLastWord(String s) {
        int n = s.length();

        int idx = n-1;

        while (s.charAt(idx) == ' ') {
            idx--;
        }

        int size = 0;
        for (int i=idx-1; i>=0; i--) {
            if (s.charAt(i) != ' ') {
                size++;
            }
            else {
                break;
            }
        }
        return size + 1;
    }
}
