class Solution {
    public int lengthOfLastWord(String s) {
        int n = s.length();
        int b = -1;
        int space = 0;

        for (int i=n-1; i>=0; i--) {
            if (!(s.charAt(i) == ' ')) {
                space = i;
                break;  
            }
        }

        for (int i=space; i>=0; i--) {
            if (s.charAt(i) == ' ') {
                b = i;
                break;  
            }
        }

        return (space - b);
    }
}
