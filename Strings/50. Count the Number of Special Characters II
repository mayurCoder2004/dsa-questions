class Solution {
    public int[] firstUpper(String word) {
        int n = word.length();
        int [] ans = new int[26];
        Arrays.fill(ans, Integer.MAX_VALUE);

        for (int i=n-1; i>=0; i--) {
            char ch = word.charAt(i);
            if (Character.isUpperCase(ch)) {
                ans[ch - 'A'] = i; 
            }
        }
        return ans;
    }
    public int[] lastLower(String word) {
        int n = word.length();
        int [] ans = new int[26];
        Arrays.fill(ans, -1);

        for (int i=0; i<n; i++) {
            char ch = word.charAt(i);
            if (Character.isLowerCase(ch)) {
                ans[ch - 'a'] = i; 
            }
        }
        return ans;
    }
    public int numberOfSpecialChars(String word) {
        int count = 0;
        int n = word.length();

        int [] upper = firstUpper(word);
        int [] lower = lastLower(word);

        for (int i=0; i<26; i++) {
            if (lower[i] != -1 && upper[i] != Integer.MAX_VALUE && lower[i] < upper[i]) {
                count++;
            }
        }
        return count;
    }
}
