class Solution {
    public String convertToBase7(int num) {
        boolean negative = num < 0;
        num = Math.abs(num);

        if (num == 0) {
            return "0";
        }

        String ans = "";

        while (num != 0) {
            int digit = num % 7;
            ans = digit + ans;
            num = num / 7;
        }

        return negative ? "-" + ans : ans;
    }
}
