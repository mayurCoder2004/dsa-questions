                                                                                // MEMOIZATION METHOD

class Solution {
    int [] dp;
    public int helper(int n) {
        if (n <= 1) {
            return n;
        }

        if (dp[n] == -1) {
            return dp[n];
        }

        dp[n] = fib(n-1) + fib(n-2);
        return dp[n];
    }
    public int fib(int n) {
        dp = new int[n+1];
        Arrays.fill(dp, -1);
        return helper(n);
    }
}                                                                                

                                                                                
                                                                                // TABULATION METHOD 1

class Solution {
    public int fib(int n) {
        if (n <= 1) return n;

        int [] dp = new int[n+1];
        Arrays.fill(dp, -1);
        
        dp[0] = 0;
        dp[1] = 1;
        for (int i=2; i<=n; i++) {
            dp[i] = dp[i-1] + dp[i-2];
        }
        return dp[n];
    }
}


                                                                                  // TABULATION METHOD 2

class Solution {
    public int fib(int n) {
        if (n <= 1) return n;
        
        int prev2 = 0;
        int prev = 1;
        for (int i=2; i<=n; i++) {
            int curr = prev + prev2;
            prev2 = prev;
            prev = curr;
        }
        return prev;
    }
}                                                                                  
