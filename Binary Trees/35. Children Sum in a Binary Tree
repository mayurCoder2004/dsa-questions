class Solution {
    public boolean isSumProperty(Node root) {
        //  code here
        if (root == null) {
            return true;
        }
        
        if (root.left == null && root.right == null) {
            return true;
        }
        
        int leftVal = (root.left == null) ? 0 : root.left.data;
        int rightVal = (root.right == null) ? 0 : root.right.data;
        
        boolean sumTrue = (leftVal + rightVal == root.data) ? true : false;
        
        return (sumTrue && isSumProperty(root.left) && isSumProperty(root.right));
    }
}
