class Solution {
    public List<Integer> inorderTraversal(TreeNode root) {
        List<Integer> ans = new ArrayList<>();
        if (root == null) return ans;
        Stack<TreeNode> st = new Stack<>();
        st.push(root);
        while (st.size() > 0) {
            TreeNode temp = st.peek();
            if (temp.left != null) {
                st.push(temp.left);
                temp.left = null;
            }
            else {
                st.pop();
                ans.add(temp.val);
                if (temp.right != null) {
                    st.push(temp.right);
                }

            }
        }
        return ans;
    }
}
