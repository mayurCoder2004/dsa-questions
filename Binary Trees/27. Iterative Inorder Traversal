class Solution {
    ArrayList<Integer> inOrder(Node root) {
        ArrayList<Integer> ans = new ArrayList<>();
        Stack<Node> st = new Stack<>();
        Node node = root;
        
        while (true) {
            if (node != null) {
                st.push(node);
                node = node.left;
            }
            else {
                if (st.isEmpty()) {
                    break;
                }
                node = st.pop();
                ans.add(node.data);
                node = node.right;
            }
        }
        return ans;
    }
}
