class Solution {
    void helper(Node root, ArrayList<Integer> arr) {
        if (root == null) {
            return;
        }
        Stack<Node> st = new Stack<>();
        st.push(root);
        
        while (!st.isEmpty()) {
            root = st.pop();
            if (root.right != null) {
                st.push(root.right);
            }
            if (root.left != null) {
                st.push(root.left);
            }
            arr.add(root.data);
        }
    }
    ArrayList<Integer> preOrder(Node root) {
        // code here
        ArrayList<Integer> arr = new ArrayList<>();
        helper(root, arr);
        return arr;
    }
}
